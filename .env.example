# ─── LLM Provider (FREE via Groq) ───────────────────────────────
# Get a free key at https://console.groq.com (no credit card needed)
LLM_API_KEY=gsk_your_groq_key_here
GROQ_API_KEY=gsk_your_groq_key_here
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_PROVIDER=openai

# ─── Cognee Mode ─────────────────────────────────────────────────
# "local"  → open-source Cognee on your machine (100% free)
# "cloud"  → Cognee Cloud API (managed, faster)
# You can also switch live from the web UI toggle!
COGNEE_MODE=local
ENABLE_BACKEND_ACCESS_CONTROL=false

# ─── LLM rate limiting (needed for Groq free tier = 6000 TPM) ────
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=1
LLM_RATE_LIMIT_INTERVAL=15

# ─── Embeddings (local fastembed — no API key needed, free) ──────
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ─── Cognee Cloud (only needed when COGNEE_MODE=cloud) ───────────
# Get these from https://platform.cognee.ai/api-keys
COGNEE_API_KEY=your_cognee_cloud_api_key
COGNEE_API_URL=https://tenant-YOUR-TENANT-ID.aws.cognee.ai
COGNEE_TENANT_ID=your-tenant-uuid
